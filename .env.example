# Requires "Message Content" privileged intent in the Discord Developer Portal:
# Application → Bot → Privileged Gateway Intents → Message Content Intent

DISCORD_TOKEN=your_token_here
ALLOWED_GUILD_ID=your_guild_id_here

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Set LLM_BACKEND to one of: groq | lmstudio | ollama
# Then configure ONLY the section for that backend — ignore the others.

LLM_BACKEND=groq

# --- Groq (cloud, free tier) --------------------------------------------------
# Sign up at https://console.groq.com to get a key.
# Free tier limits: llama-3.1-8b-instant = 14,400 req/day | llama-3.3-70b-versatile = 1,000 req/day
# Comma-separated — add multiple keys for automatic rotation when rate limits are hit
GROQ_API_KEYS=your_groq_key_here,optional_second_key
GROQ_MODEL=llama-3.3-70b-versatile
# Used automatically when all primary model keys are rate-limited
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# --- LM Studio (local network) ------------------------------------------------
# LM Studio running on a machine accessible via local network or Tailscale.
#LMSTUDIO_HOST=100.x.x.x
#LMSTUDIO_PORT=1234
#LMSTUDIO_MODEL=your-loaded-model
#LMSTUDIO_API_KEY=

# --- Ollama (local) -----------------------------------------------------------
#OLLAMA_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.1:8b

# ── Embeddings ────────────────────────────────────────────────────────────────
# Used for semantic memory retrieval — independent of the chat backend.
# Recommended: Jina AI (free, 1M tokens/month) — sign up at https://jina.ai
# When using LM Studio you can omit this and point EMBEDDING_URL at your local instance instead.
EMBEDDING_API_KEY=your_jina_key_here
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_URL=https://api.jina.ai/v1/embeddings

# How many relevant memory facts to inject per reply (default: 5)
MEMORY_TOP_K=5

# ── Bot behaviour ─────────────────────────────────────────────────────────────
SYSTEM_PROMPT_FILE=prompts/system_prompt.txt
MAX_HISTORY=20
HISTORY_TTL=14400
DEBOUNCE_SECONDS=3.0
CONTEXT_WINDOW_SECONDS=120

# Channels the bot cannot talk in (comma-separated IDs, leave empty for none)
BLOCKED_CHANNELS=

# ── Features ──────────────────────────────────────────────────────────────────
# Giphy — leave empty to disable GIFs
GIPHY_API_KEY=
GIF_COOLDOWN=300

# Channels the bot posts random conversation starters in (comma-separated IDs)
RANDOM_CONVO_CHANNELS=
RANDOM_CONVO_INTERVAL=10

# Chance (0–100) the bot randomly chimes in on any message
RANDOM_REPLY_CHANCE=8
RANDOM_REPLY_COOLDOWN=180

# ── Advanced ──────────────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=4
DATABASE_URL=postgresql://user:password@host:5432/dbname
LLM_ERROR_COOLDOWN=60
